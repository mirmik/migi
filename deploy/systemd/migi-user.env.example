# Values are parsed by systemd, not by a shell. Keep every value whitespace-free.
MIGI_LISTEN=:8443
MIGI_INGEST_LISTEN=127.0.0.1:8787
# Empty disables the authenticated public agent HTTPS listener.
MIGI_AGENT_LISTEN=
MIGI_ADMIN_LISTEN=192.168.0.61:8788
# Leave empty to enter the reachable HTTPS endpoint in the administration UI per pairing.
MIGI_PUBLIC_ENDPOINT=
# Optional default offered when creating agent credentials in the administration UI.
MIGI_AGENT_ENDPOINT=
