# Values are parsed by systemd, not by a shell. Keep every value whitespace-free.
# Bind QUIC to an unprivileged internal UDP port and forward the public UDP port
# at the router. The service intentionally has no CAP_NET_BIND_SERVICE.
MIGI_LISTEN=:8443
MIGI_INGEST_LISTEN=127.0.0.1:8787
MIGI_ADMIN_LISTEN=127.0.0.1:8788
MIGI_PUBLIC_ENDPOINT=https://203.0.113.10:10443
MIGI_DATABASE=/var/lib/migi/migi.db
